# Copy this to .env.jetson in the repository root. .env.jetson is ignored by git.
JETSON_SSH_HOST=192.168.1.12
JETSON_SSH_USER=weizheng
JETSON_SSH_PORT=22
JETSON_REPO_DIR=~/code/jetson-vlm-lab

# Prefer SSH keys. If you must use a password locally, keep it only in .env.jetson.
# JETSON_SSH_PASSWORD=
# JETSON_SSH_PASSWORD_FILE=

# Extra SSH options are split on spaces.
# JETSON_SSH_OPTS=-o ConnectTimeout=10
